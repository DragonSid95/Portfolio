---
const base = import.meta.env.BASE_URL;
const withBase = (p) => `${base}${p.replace(/^\/+/, '')}`;

const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/contact', label: 'Contact' },
];

const norm = (p) => '/' + p.replace(/^\/+|\/+$/g, '');
const current = norm(Astro.url.pathname);
---

<nav class="navbar">
  <div class="nav-container">
    <a href={base} class="nav-logo">Portfolio</a>
    <ul class="nav-menu" id="navMenu">
      {
        links.map((link) => (
          <li class="nav-item">
            <a
              href={withBase(link.href)}
              class:list={['nav-link', { active: current === norm(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode" title="Toggle theme">
      <i class="fas fa-moon"></i>
    </button>
    <div class="nav-toggle" id="navToggle" role="button" aria-label="Open menu" tabindex="0">
      <i class="fas fa-bars"></i>
    </div>
  </div>
</nav>
