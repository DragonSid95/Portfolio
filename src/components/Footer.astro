---
const base = import.meta.env.BASE_URL;
const withBase = (p) => `${base}${p.replace(/^\/+/, '')}`;
const year = new Date().getFullYear();
const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-brand">
      <h3>Portfolio</h3>
      <p>Creating digital experiences that make an impact.</p>
    </div>
    <div class="footer-links">
      <h4>Quick Links</h4>
      <ul>
        {links.map((link) => <li><a href={withBase(link.href)}>{link.label}</a></li>)}
      </ul>
    </div>
    <div class="footer-social">
      <h4>Connect</h4>
      <div class="social-icons">
        <a href="#" class="social-icon" aria-label="LinkedIn"><i class="fab fa-linkedin"></i></a>
        <a href="#" class="social-icon" aria-label="GitHub"><i class="fab fa-github"></i></a>
        <a href="#" class="social-icon" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; {year} Your Name. All rights reserved.</p>
  </div>
</footer>
